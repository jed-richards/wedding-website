PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only secrets (never exposed to the browser). Get the service role key
# from the Supabase dashboard: Project Settings > API > service_role secret.
SUPABASE_SERVICE_ROLE_KEY=

# Optional, local Google sign-in testing only (see supabase/config.toml
# [auth.external.google]). Not used in production — prod Google config lives
# in the Supabase dashboard under Auth > Providers.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
